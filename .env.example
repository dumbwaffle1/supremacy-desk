# ─── Copy to .env.local for local dev; set the same keys in Vercel for prod ───

# Convex deployment (written automatically by `npx convex dev`).
# NEXT_PUBLIC_CONVEX_URL is the public client URL (https://<name>.convex.cloud).
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Admin email override (optional). Defaults to the value baked into
# src/config/constants.ts if unset.
NEXT_PUBLIC_ADMIN_EMAIL=

# Web push (PWA notifications). Generate once: npx web-push generate-vapid-keys
# Public key goes here AND in Vercel; the private key + subject go on Convex:
#   npx convex env set VAPID_PUBLIC_KEY <pub>
#   npx convex env set VAPID_PRIVATE_KEY <priv>
#   npx convex env set VAPID_SUBJECT mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── The following live on the CONVEX deployment, NOT in this file ───
# Set them with `npx convex env set <NAME> <value>` (see DEPLOY.md):
#   AUTH_RESEND_KEY   — Resend API key (re_...) for sending magic-link emails
#   AUTH_EMAIL_FROM   — verified sender, e.g. "Supremacy Desk <desk@yourdomain>"
#   JWT_PRIVATE_KEY   — generated by `node scripts/generateKeys.mjs`
#   JWKS              — generated by `node scripts/generateKeys.mjs`
#   SITE_URL          — your app origin (http://localhost:3000 in dev)
